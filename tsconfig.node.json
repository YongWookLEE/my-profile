{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./.cache/vite-config",
    "tsBuildInfoFile": "./.cache/tsconfig.node.tsbuildinfo"
  },
  "include": ["vite.config.ts"]
}
